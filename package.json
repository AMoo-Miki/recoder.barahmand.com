{
  "name": "recoder.barahmand.com",
  "version": "1.0.0",
  "private": true,
  "description": "Forms Recoder — recode column values in spreadsheets to numeric codes.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:property": "vitest run tests/unit/recoder.property.test.js",
    "test:adversarial": "vitest run tests/unit/recoder.adversarial.test.js",
    "test:perf": "vitest run tests/unit/recoder.perf.test.js",
    "test:fixtures": "vitest run tests/unit/recoder.fixtures.test.js",
    "test:a11y": "vitest run tests/integration/index.a11y.test.js",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:live": "playwright test --config=playwright.live.config.mjs",
    "test:all": "npm run test && npm run test:e2e",
    "fixtures:regenerate": "node tests/fixtures/generate.mjs",
    "build": "node scripts/build.mjs",
    "build:clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "serve": "npx --yes http-server . -p 8765 -c-1 --silent",
    "serve:dist": "npx --yes http-server dist -p 8765 -c-1 --silent"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.3",
    "esbuild": "^0.28.0",
    "fast-check": "^4.7.0",
    "jsdom": "^29.0.2",
    "vitest": "^4.1.5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}
